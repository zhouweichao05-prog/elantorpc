{"ast":null,"code":"export default {\n  name: 'AboutView',\n  data() {\n    return {\n      companyValues: [{\n        icon: '🎯',\n        title: 'Our Mission',\n        desc: 'To protect people and environments by providing the most effective, reliable, and affordable ULV fogging solutions worldwide.'\n      }, {\n        icon: '🔭',\n        title: 'Our Vision',\n        desc: 'To become the global leader in ULV cold fogging technology, setting the standard for quality and innovation.'\n      }, {\n        icon: '💎',\n        title: 'Our Values',\n        desc: 'Quality first, customer-centric, continuous innovation, and honest business practices.'\n      }],\n      certifications: [{\n        badge: 'CE',\n        name: 'CE Marking',\n        desc: 'European Conformity'\n      }, {\n        badge: 'RoHS',\n        name: 'RoHS Compliant',\n        desc: 'Hazardous Substances'\n      }, {\n        badge: 'ISO',\n        name: 'ISO 9001',\n        desc: 'Quality Management'\n      }, {\n        badge: 'SGS',\n        name: 'SGS Tested',\n        desc: 'Third-party Verified'\n      }]\n    };\n  }\n};","map":{"version":3,"names":["name","data","companyValues","icon","title","desc","certifications","badge"],"sources":["/home/ubuntu/elantorpco/src/views/AboutView.vue"],"sourcesContent":["<template>\n  <main>\n    <!-- Hero -->\n    <section class=\"section bg-primary-700 text-white\" style=\"margin-top: 80px;\">\n      <div class=\"container text-center\">\n        <h1>About Elantor</h1>\n        <p class=\"section-subtitle text-white\">A professional ULV Cold Fogger manufacturer dedicated to providing world-class fogging solutions.</p>\n      </div>\n    </section>\n\n    <!-- Story -->\n    <section class=\"section\">\n      <div class=\"container\">\n        <div class=\"story-grid\">\n          <div>\n            <h2>Our Story</h2>\n            <p>Elantor was founded with a clear mission: to provide professional-grade ULV cold fogging equipment that helps protect people, animals, and environments from harmful pathogens and pests.</p>\n            <p>With over a decade of manufacturing experience, we have developed a comprehensive range of ULV cold foggers that combine advanced technology with user-friendly design. Our products are trusted by healthcare facilities, agricultural businesses, and public health organizations across more than 50 countries.</p>\n            <router-link to=\"/contact\" class=\"btn-primary\">Get in Touch</router-link>\n          </div>\n          \n          <div class=\"stats-grid\">\n            <div class=\"stat-card\">\n              <div class=\"stat-number\">2014</div>\n              <div class=\"stat-label\">Founded</div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-number\">50+</div>\n              <div class=\"stat-label\">Countries</div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-number\">500+</div>\n              <div class=\"stat-label\">Clients</div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-number\">CE</div>\n              <div class=\"stat-label\">Certified</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Values -->\n    <section class=\"section bg-gray-50\">\n      <div class=\"container\">\n        <h2 class=\"section-title\">Our Mission & Values</h2>\n        <div class=\"grid grid-3\">\n          <div v-for=\"value in companyValues\" :key=\"value.title\" class=\"card p-8 text-center\">\n            <div class=\"value-icon\">{{ value.icon }}</div>\n            <h3>{{ value.title }}</h3>\n            <p class=\"text-gray-600\">{{ value.desc }}</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Certifications -->\n    <section class=\"section\">\n      <div class=\"container\">\n        <h2 class=\"section-title\">Certifications & Standards</h2>\n        <div class=\"grid grid-4\">\n          <div v-for=\"cert in certifications\" :key=\"cert.name\" class=\"card p-6 text-center\">\n            <div class=\"cert-badge\">{{ cert.badge }}</div>\n            <div class=\"cert-name\">{{ cert.name }}</div>\n            <div class=\"cert-desc\">{{ cert.desc }}</div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- CTA -->\n    <section class=\"section bg-primary-700 text-white text-center\">\n      <div class=\"container\">\n        <h2>Partner With Elantor</h2>\n        <p>Join hundreds of satisfied customers worldwide.</p>\n        <router-link to=\"/contact\" class=\"btn-primary\" style=\"background-color: var(--white); color: var(--primary-700);\">Contact Us Today</router-link>\n      </div>\n    </section>\n  </main>\n</template>\n\n<script>\nexport default {\n  name: 'AboutView',\n  data() {\n    return {\n      companyValues: [\n        {\n          icon: '🎯',\n          title: 'Our Mission',\n          desc: 'To protect people and environments by providing the most effective, reliable, and affordable ULV fogging solutions worldwide.'\n        },\n        {\n          icon: '🔭',\n          title: 'Our Vision',\n          desc: 'To become the global leader in ULV cold fogging technology, setting the standard for quality and innovation.'\n        },\n        {\n          icon: '💎',\n          title: 'Our Values',\n          desc: 'Quality first, customer-centric, continuous innovation, and honest business practices.'\n        }\n      ],\n      certifications: [\n        { badge: 'CE', name: 'CE Marking', desc: 'European Conformity' },\n        { badge: 'RoHS', name: 'RoHS Compliant', desc: 'Hazardous Substances' },\n        { badge: 'ISO', name: 'ISO 9001', desc: 'Quality Management' },\n        { badge: 'SGS', name: 'SGS Tested', desc: 'Third-party Verified' }\n      ]\n    }\n  }\n}\n</script>\n\n<style scoped>\n.story-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 3rem;\n  align-items: center;\n}\n\n.stats-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 1rem;\n}\n\n.stat-card {\n  background-color: var(--primary-700);\n  color: var(--white);\n  padding: 2rem;\n  border-radius: 1rem;\n  text-align: center;\n}\n\n.stat-number {\n  font-size: 2.5rem;\n  font-weight: 900;\n  margin-bottom: 0.5rem;\n}\n\n.stat-label {\n  font-size: 0.9rem;\n  opacity: 0.9;\n}\n\n.value-icon {\n  font-size: 2.5rem;\n  margin-bottom: 1rem;\n}\n\n.cert-badge {\n  font-size: 2rem;\n  font-weight: 900;\n  color: var(--primary-700);\n  margin-bottom: 0.5rem;\n}\n\n.cert-name {\n  font-weight: 600;\n  margin-bottom: 0.5rem;\n}\n\n.cert-desc {\n  font-size: 0.8rem;\n  color: var(--gray-500);\n}\n\n@media (max-width: 768px) {\n  .story-grid {\n    grid-template-columns: 1fr;\n  }\n  \n  .stats-grid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n}\n</style>\n"],"mappings":"AAmFA,eAAe;EACbA,IAAI,EAAE,WAAW;EACjBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,aAAa,EAAE,CACb;QACEC,IAAI,EAAE,IAAI;QACVC,KAAK,EAAE,aAAa;QACpBC,IAAI,EAAE;MACR,CAAC,EACD;QACEF,IAAI,EAAE,IAAI;QACVC,KAAK,EAAE,YAAY;QACnBC,IAAI,EAAE;MACR,CAAC,EACD;QACEF,IAAI,EAAE,IAAI;QACVC,KAAK,EAAE,YAAY;QACnBC,IAAI,EAAE;MACR,EACD;MACDC,cAAc,EAAE,CACd;QAAEC,KAAK,EAAE,IAAI;QAAEP,IAAI,EAAE,YAAY;QAAEK,IAAI,EAAE;MAAsB,CAAC,EAChE;QAAEE,KAAK,EAAE,MAAM;QAAEP,IAAI,EAAE,gBAAgB;QAAEK,IAAI,EAAE;MAAuB,CAAC,EACvE;QAAEE,KAAK,EAAE,KAAK;QAAEP,IAAI,EAAE,UAAU;QAAEK,IAAI,EAAE;MAAqB,CAAC,EAC9D;QAAEE,KAAK,EAAE,KAAK;QAAEP,IAAI,EAAE,YAAY;QAAEK,IAAI,EAAE;MAAuB;IAErE;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}